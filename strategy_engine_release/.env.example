# =============================================================
# Copy this file to `.env` and edit values for your environment.
# Never commit your real .env to git.
# =============================================================

# --- Database -----------------------------------------------
# For local development with zero install, use SQLite (default):
DATABASE_URL=sqlite:///./strategy_engine.db

# For production with MySQL, comment the line above and use:
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/strategy_engine

# --- JWT ----------------------------------------------------
# Generate a real secret in production with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- OpenAI (legacy) ----------------------------------------
OPENAI_API_KEY=

# --- Anthropic Claude (recommended) -------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
